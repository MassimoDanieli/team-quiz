{
  "name": "team-quiz",
  "version": "1.5.0",
  "description": "Real-time two-team quiz game for early-talent sessions",
  "main": "server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node server.js",
    "test": "node --test test/*.test.js",
    "validate": "node scripts/validate-sets.js",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.js\"",
    "format:check": "prettier --check \"**/*.js\""
  },
  "dependencies": {
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "pino": "^9.3.2",
    "socket.io": "^4.7.5"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.3",
    "socket.io-client": "^4.7.5"
  }
}
