# Team Quiz — environment configuration
# Copy to `.env` and fill in. Keep `.env` out of version control (chmod 600).
#   cp .env.example .env && chmod 600 .env

# ---- Secrets (set these) ----

# Super-admin password. If EMPTY, the super-admin panel is LOCKED and no admin
# accounts can be created — so set this before first run.
SUPER_ADMIN_PASSWORD=

# Super-admin username (optional; defaults to "superadmin").
SUPER_ADMIN_USER=superadmin

# Optional shared join password for players. Empty = anyone with a room code
# can join. Recommended when the deployment is internet-facing.
SHARED_PASSWORD=

# ---- Gameplay tuning (optional) ----
WIN_SCORE=3
TIMER_SECONDS=60
MAX_PLAYERS=200
LOG_LEVEL=info

# ---- Networking ----
# Host interface the app binds to when running WITHOUT the proxy profile.
# 127.0.0.1 = localhost only (safest; put a proxy in front). 0.0.0.0 = all interfaces.
BIND_ADDR=127.0.0.1

# ---- TLS proxy (only used with `--profile proxy`) ----
QUIZ_DOMAIN=quiz.example.com
TLS_EMAIL=you@example.com
